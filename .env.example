# Copy this file to `.env` for local configuration. Do not commit `.env`.

JOBPILOT_DEFAULT_WORKSPACE=.jobpilot_workspace

# Default offline provider. No API key is needed for mock mode.
JOBPILOT_LLM_PROVIDER=mock

# OpenAI-compatible provider opt-in.
# To enable real external calls, set JOBPILOT_LLM_PROVIDER=openai_compatible
# and fill the three values below.
JOBPILOT_OPENAI_BASE_URL=https://api.openai.com/v1
JOBPILOT_OPENAI_API_KEY=
JOBPILOT_OPENAI_MODEL=gpt-4o-mini

# Optional provider-specific request tuning. Supported value: minimax.
JOBPILOT_OPENAI_PROVIDER_PRESET=

JOBPILOT_LLM_TIMEOUT_SECONDS=30
JOBPILOT_LLM_MAX_RETRIES=1
JOBPILOT_LLM_LOG_PAYLOADS=0

# Chatbox orchestration core.
JOBPILOT_CHAT_CORE=keyword
JOBPILOT_CHAT_CORE_STRICT=0
