        <mxCell id="next6" value="后续路线&#xa;P10-CLI 覆盖度复审&#xa;→ P10-CLI-M0 开发前启动审计&#xa;→ P10-CLI-M1 到 M5 自动化开发&#xa;→ P10-MCP 或 P10-MARKET-OPTIN 另行立项" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=14;" vertex="1" parent="1"><mxGeometry x="960" y="140" width="320" height="180" as="geometry"/></mxCell>
