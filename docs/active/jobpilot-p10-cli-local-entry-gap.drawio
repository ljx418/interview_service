        <mxCell id="flow4c" value="Router → ApiClient → existing job/artifact/report data → OutputRenderer prints summary, source refs, pending confirmations, report paths" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontSize=14;" vertex="1" parent="1"><mxGeometry x="390" y="360" width="800" height="80" as="geometry"/></mxCell>
