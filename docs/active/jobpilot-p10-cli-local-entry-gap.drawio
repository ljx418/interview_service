        <mxCell id="flow4b" value="Router → SafetyGate confirms local examples only → existing demo path / API → artifact ids + report paths → redacted audit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontSize=14;" vertex="1" parent="1"><mxGeometry x="390" y="240" width="800" height="80" as="geometry"/></mxCell>
