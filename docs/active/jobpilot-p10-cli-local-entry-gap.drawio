        <mxCell id="col7c" value="P10-CLI 适配要求" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="810" y="180" width="480" height="42" as="geometry"/></mxCell>
        <mxCell id="r7a1" value="workspace status" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="80" y="235" width="260" height="70" as="geometry"/></mxCell>
        <mxCell id="r7a2" value="GET /api/health&#xa;GET /api/workspace/status&#xa;GET /api/provider/status&#xa;GET /api/provider/runtime-config" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontSize=12;" vertex="1" parent="1"><mxGeometry x="360" y="235" width="430" height="70" as="geometry"/></mxCell>
        <mxCell id="r7a3" value="ApiClient.status() 聚合服务、workspace、provider、market provider、reports 状态；configured / consented / called 必须分开。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontSize=12;" vertex="1" parent="1"><mxGeometry x="810" y="235" width="480" height="70" as="geometry"/></mxCell>
        <mxCell id="r7b1" value="demo run --example" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="80" y="315" width="260" height="60" as="geometry"/></mxCell>
        <mxCell id="r7b2" value="POST /api/workflows/p2-demo/run" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontSize=12;" vertex="1" parent="1"><mxGeometry x="360" y="315" width="430" height="60" as="geometry"/></mxCell>
        <mxCell id="r7b3" value="只允许 examples / fixture；不得读取真实资料，不触发真实 provider。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontSize=12;" vertex="1" parent="1"><mxGeometry x="810" y="315" width="480" height="60" as="geometry"/></mxCell>
        <mxCell id="r7c1" value="jobs list" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="80" y="385" width="260" height="60" as="geometry"/></mxCell>
        <mxCell id="r7c2" value="GET /api/jobs?workspace_id=..." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontSize=12;" vertex="1" parent="1"><mxGeometry x="360" y="385" width="430" height="60" as="geometry"/></mxCell>
        <mxCell id="r7c3" value="输出标题、城市、来源、当前目标、source refs 数量；不读取 source_url 网页。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontSize=12;" vertex="1" parent="1"><mxGeometry x="810" y="385" width="480" height="60" as="geometry"/></mxCell>
        <mxCell id="r7d1" value="artifacts list / show" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="80" y="455" width="260" height="70" as="geometry"/></mxCell>
        <mxCell id="r7d2" value="GET /api/artifacts&#xa;artifact version APIs" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontSize=12;" vertex="1" parent="1"><mxGeometry x="360" y="455" width="430" height="70" as="geometry"/></mxCell>
        <mxCell id="r7d3" value="默认摘要；展示版本、确认状态、source refs、pending confirmations；不得打印敏感全文。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontSize=12;" vertex="1" parent="1"><mxGeometry x="810" y="455" width="480" height="70" as="geometry"/></mxCell>
        <mxCell id="r7e1" value="reports open --no-browser" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="80" y="535" width="260" height="60" as="geometry"/></mxCell>
        <mxCell id="r7e2" value="docs/reports/ 本地文件" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontSize=12;" vertex="1" parent="1"><mxGeometry x="360" y="535" width="430" height="60" as="geometry"/></mxCell>
        <mxCell id="r7e3" value="LocalReportLocator 选择最新中文报告；--no-browser 只打印路径；打开失败不能伪造成功。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontSize=12;" vertex="1" parent="1"><mxGeometry x="810" y="535" width="480" height="60" as="geometry"/></mxCell>
        <mxCell id="forbid7" value="禁止默认实现：真实 provider adapter、招聘平台 connector、真实市场 provider、ASR adapter、MCP server wrapper、FastAPI 自动启动、报告生成器、workspace 扫描器、cleanup/migration apply。若需要这些能力，必须单独立项。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontStyle=1;fontSize=14;" vertex="1" parent="1"><mxGeometry x="130" y="675" width="1090" height="80" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p10-cli-page-8" name="8 工作流树与错误码">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title8" value="P10-CLI 工作流树、输出 envelope 与错误码" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1f2937;fontColor=#ffffff;strokeColor=#111827;fontStyle=1;fontSize=18;" vertex="1" parent="1"><mxGeometry x="40" y="30" width="1280" height="60" as="geometry"/></mxCell>
        <mxCell id="wf8a" value="Workflow A: workspace status&#xa;ParseCommand → ResolveConfig → CommandSafetyGate → ApiHealthCheck → WorkspaceStatusFetch → ProviderStatusFetch → ReportIndexFetch → RenderOutput → CommandAuditLog" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontSize=13;" vertex="1" parent="1"><mxGeometry x="70" y="125" width="570" height="105" as="geometry"/></mxCell>
        <mxCell id="wf8b" value="Workflow B: demo run --example&#xa;ParseCommand → SafetyGate(example only) → EnsureApiAvailable → EnsureWorkspace → RunExistingDemo → SummarizeArtifactsAndReports → RenderOutput → CommandAuditLog" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontSize=13;" vertex="1" parent="1"><mxGeometry x="70" y="255" width="570" height="115" as="geometry"/></mxCell>
        <mxCell id="wf8c" value="Workflow C: artifacts show &lt;id&gt;&#xa;ParseCommand → CommandSafetyGate → FetchArtifactVersions → FetchSelectedVersion → RedactAndSummarize → RenderOutput(source refs / pending confirmations) → CommandAuditLog" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontSize=13;" vertex="1" parent="1"><mxGeometry x="70" y="395" width="570" height="115" as="geometry"/></mxCell>
        <mxCell id="env8" value="统一 JSON envelope&#xa;ok / command / workspace_id / data_source / provider_state / data / warnings / next_actions / meta&#xa;失败时：error.code / message / hint / exit_code" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=13;" vertex="1" parent="1"><mxGeometry x="720" y="125" width="560" height="115" as="geometry"/></mxCell>
        <mxCell id="codes8" value="Exit code 策略&#xa;0 成功&#xa;1 参数或用法错误&#xa;2 本地服务不可用&#xa;3 workspace 不存在&#xa;4 安全门拒绝&#xa;5 本地数据为空&#xa;10 未分类内部错误" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=14;" vertex="1" parent="1"><mxGeometry x="720" y="285" width="250" height="230" as="geometry"/></mxCell>
        <mxCell id="handoff8" value="Handoff contracts&#xa;Router → Handler: ParsedCommand&#xa;Handler → SafetyGate: command / flags / workspace / data_mode&#xa;Handler → ApiClient: method / path / query / body / timeout&#xa;Handler → OutputRenderer: normalized result / warnings / next_actions&#xa;Handler → AuditLog: redacted command summary / exit code" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3f4f6;strokeColor=#6b7280;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1000" y="285" width="280" height="230" as="geometry"/></mxCell>
        <mxCell id="freeze8" value="M0 冻结项：CLI 不自动启动 FastAPI；reports open 只定位/打开已有报告，不生成报告；workspace 解析优先级固定为 --workspace &gt; JOBPILOT_WORKSPACE &gt; 当前目录 .jobpilot_workspace &gt; 失败 exit 3。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontStyle=1;fontSize=14;" vertex="1" parent="1"><mxGeometry x="150" y="555" width="1040" height="80" as="geometry"/></mxCell>
        <mxCell id="deny8" value="失败路径必须可验收：服务未启动→exit 2；workspace 不存在→exit 3；高风险请求→exit 4；无本地数据→exit 5。任何失败都不能伪造成绿色通过。本图只支撑 P10-CLI 自动化开发启动，不支撑整个产品化阶段一次性开工。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontStyle=1;fontSize=14;" vertex="1" parent="1"><mxGeometry x="150" y="660" width="1040" height="90" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
