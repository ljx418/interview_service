        <mxCell id="exit6" value="文档阶段出门条件&#xa;active 文档口径一致&#xa;drawio XML 可解析且不超过 8 页&#xa;实体状态、命令清单、上下游关系清楚&#xa;审计明确不进入代码实现" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;" vertex="1" parent="1"><mxGeometry x="80" y="140" width="360" height="180" as="geometry"/></mxCell>
