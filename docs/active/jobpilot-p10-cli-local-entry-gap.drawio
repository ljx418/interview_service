        <mxCell id="flow4a" value="Router → ConfigResolver → SafetyGate → ApiClient GET /api/health + status summaries → OutputRenderer → ExitCodePolicy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontSize=14;" vertex="1" parent="1"><mxGeometry x="390" y="120" width="800" height="80" as="geometry"/></mxCell>
