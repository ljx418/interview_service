        <mxCell id="gate5" value="最低验收命令&#xa;python3 -m pytest&#xa;npm --prefix apps/chatbox run build&#xa;drawio XML parse&#xa;jobpilot --help&#xa;jobpilot workspace status&#xa;jobpilot demo run --example&#xa;jobpilot jobs list&#xa;jobpilot artifacts list&#xa;jobpilot reports open --no-browser" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=13;" vertex="1" parent="1"><mxGeometry x="960" y="130" width="310" height="270" as="geometry"/></mxCell>
