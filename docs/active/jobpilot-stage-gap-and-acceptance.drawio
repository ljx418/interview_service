        <mxCell id="3" value="1 打开本地 Chatbox-native 工作台&#10;顶部服务状态 + 左侧态势 + 中央 Chatbox + 右侧产物台同时可见" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5f5e3;strokeColor=#1e8449;fontColor=#10201d;fontStyle=1;spacing=8;arcSize=8;" vertex="1" parent="1">
