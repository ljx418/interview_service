  <diagram id="5_用户体验路线" name="5 用户体验路线">
    <mxGraphModel dx="1434" dy="844" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="2" value="用户操作与体验路线：Chatbox 发起，左右两侧响应" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1f4f46;strokeColor=#0b2f2a;fontColor=#10201d;fontStyle=1;spacing=8;arcSize=8;" vertex="1" parent="1">
