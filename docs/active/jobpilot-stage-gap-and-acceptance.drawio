          <mxGeometry x="460" y="315" width="300" height="145" as="geometry" />
        </mxCell>
        <mxCell id="p6_cmd" value="最低复验命令&lt;br&gt;.venv/bin/python -m pytest&lt;br&gt;npm --prefix apps/chatbox run build&lt;br&gt;python3 drawio XML parse&lt;br&gt;rg 检查 P4/P5/P6 口径" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;spacing=8;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="805" y="315" width="285" height="145" as="geometry" />
        </mxCell>
        <mxCell id="p6_rule" value="审计原则&lt;br&gt;自动化候选通过不等于 P5 冻结；drawio 方向认可不等于功能验收通过；用户授权真实资料也必须在报告中脱敏；真实外部 provider 必须 P6 单独确认。&lt;br&gt;下一步：P5-REAL + 人工体验 + final closure audit。" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;spacing=8;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="55" y="565" width="1035" height="100" as="geometry" />
