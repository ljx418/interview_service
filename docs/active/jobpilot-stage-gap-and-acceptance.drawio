        <mxCell id="2" value="P9 里程碑、验收门槛与出门条件" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1f4f46;strokeColor=#0b2f2a;fontColor=#10201d;fontStyle=1;spacing=8;arcSize=8;" vertex="1" parent="1">
