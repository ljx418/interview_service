        <mxCell id="7" value="5 生成面向目标 JD 的申请包草稿&#10;简历/故事/source refs/pending confirmations 可见" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5f5e3;strokeColor=#1e8449;fontColor=#10201d;fontStyle=1;spacing=8;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="860" y="340" width="330" height="120" as="geometry" />
        </mxCell>
        <mxCell id="8" value="6 用 Chatbox 更新投递流程&#10;例如“一面通过，下周三二面”；左侧流程泳道和右侧摘要更新" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5f5e3;strokeColor=#1e8449;fontColor=#10201d;fontStyle=1;spacing=8;arcSize=8;" vertex="1" parent="1">
