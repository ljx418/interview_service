  <diagram name="5 开发及验收计划" id="p81-page-5">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1280" pageHeight="720" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p5-title" value="5 P8.1 开发及验收计划" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ffffff;fontSize=18;fontStyle=1;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="30" y="18" width="500" height="40" as="geometry" /></mxCell>
        <mxCell id="p5-m0" value="P8.1-M0&lt;br&gt;开发前启动审计&lt;br&gt;复核 PRD、目标架构、当前 UI、验收门槛&lt;br&gt;无重大偏差才进入开发" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1"><mxGeometry x="50" y="100" width="190" height="130" as="geometry" /></mxCell>
        <mxCell id="p5-m1" value="P8.1-M1&lt;br&gt;Chatbox-first 布局重构&lt;br&gt;timeline、状态机、composer 首屏优先&lt;br&gt;证据：1200/1440/1920 截图" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1"><mxGeometry x="280" y="100" width="190" height="130" as="geometry" /></mxCell>
        <mxCell id="p5-m2" value="P8.1-M2&lt;br&gt;资料/JD/简历入口迁移&lt;br&gt;工具紧贴输入框或进入左右辅助面板&lt;br&gt;证据：入口可达截图" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1"><mxGeometry x="510" y="100" width="190" height="130" as="geometry" /></mxCell>
        <mxCell id="p5-m3" value="P8.1-M3&lt;br&gt;状态机与工作台职责&lt;br&gt;等待资料 / 解析 / 生成 / 待确认 / 可导出 / 失败恢复&lt;br&gt;证据：右侧产物截图" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1"><mxGeometry x="740" y="100" width="190" height="145" as="geometry" /></mxCell>
        <mxCell id="p5-m4" value="P8.1-M4&lt;br&gt;响应式和视觉质量&lt;br&gt;1200/1440/1920/720/390 无重叠、无错位&lt;br&gt;默认 Chatbox 优先" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1"><mxGeometry x="970" y="100" width="190" height="130" as="geometry" /></mxCell>
        <mxCell id="p5-m5" value="P8.1-M5&lt;br&gt;中文自动化验收报告&lt;br&gt;真实界面截图、目标架构、当前实现、体验路径、PRD 检视、未验证范围" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1"><mxGeometry x="510" y="380" width="250" height="135" as="geometry" /></mxCell>
        <mxCell id="p5-gate" value="每个子阶段出门前必须：单独计划 → 审计意见闭环 → 实现 → 端到端验收 → PRD 规格检视。若出现重大偏差或虚假验收风险，打回计划阶段。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;align=left;spacing=12;" vertex="1" parent="1"><mxGeometry x="80" y="585" width="1120" height="70" as="geometry" /></mxCell>
        <mxCell id="p5-e1" style="endArrow=block;html=1;rounded=0;strokeColor=#666666;" edge="1" parent="1" source="p5-m0" target="p5-m1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p5-e2" style="endArrow=block;html=1;rounded=0;strokeColor=#666666;" edge="1" parent="1" source="p5-m1" target="p5-m2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p5-e3" style="endArrow=block;html=1;rounded=0;strokeColor=#666666;" edge="1" parent="1" source="p5-m2" target="p5-m3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p5-e4" style="endArrow=block;html=1;rounded=0;strokeColor=#666666;" edge="1" parent="1" source="p5-m3" target="p5-m4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p5-e5" style="endArrow=block;html=1;rounded=0;strokeColor=#666666;" edge="1" parent="1" source="p5-m4" target="p5-m5"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="6 里程碑门槛与出门条件" id="p81-page-6">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1280" pageHeight="720" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p6-title" value="6 里程碑门槛与出门条件" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ffffff;fontSize=18;fontStyle=1;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="30" y="18" width="520" height="40" as="geometry" /></mxCell>
        <mxCell id="p6-doc" value="文档出门&lt;br&gt;PRD / 架构 / 里程碑 / 验收 / 追踪矩阵 / roadmap / drawio 口径一致&lt;br&gt;第 4 页能看清实体关系和状态颜色&lt;br&gt;不写成 UI 已实现" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1"><mxGeometry x="70" y="100" width="330" height="170" as="geometry" /></mxCell>
        <mxCell id="p6-dev" value="开发出门&lt;br&gt;中央 Chatbox 首屏优先&lt;br&gt;工具入口靠近输入框&lt;br&gt;右侧工作台职责稳定&lt;br&gt;普通聊天不静默写 artifact" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1"><mxGeometry x="475" y="100" width="330" height="170" as="geometry" /></mxCell>
        <mxCell id="p6-accept" value="验收出门&lt;br&gt;.venv/bin/python -m pytest&lt;br&gt;npm --prefix apps/chatbox run build&lt;br&gt;drawio XML parse&lt;br&gt;1200 / 1440 / 1920 / 720 / 390 真实截图&lt;br&gt;中文 HTML 报告" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1"><mxGeometry x="880" y="100" width="330" height="190" as="geometry" /></mxCell>
        <mxCell id="p6-user" value="用户体验出门&lt;br&gt;用户第一眼知道可以聊天&lt;br&gt;知道需要补哪些资料和为什么&lt;br&gt;能粘贴 JD、选择岗位、生成简历&lt;br&gt;能看到 source refs、待确认项和导出预检" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1"><mxGeometry x="70" y="365" width="525" height="150" as="geometry" /></mxCell>
        <mxCell id="p6-fail" value="打回条件&lt;br&gt;聊天仍被大表单压住&lt;br&gt;移动端默认不是 Chatbox&lt;br&gt;按钮错位或文字重叠&lt;br&gt;报告用概念图替代真实截图&lt;br&gt;报告声称平台/真实 provider/真实资料已通过" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1"><mxGeometry x="685" y="365" width="525" height="170" as="geometry" /></mxCell>
        <mxCell id="p6-note" value="P8.1 通过只表示 Chatbox-first 信息架构和本地/mock UI 验收通过，不表示招聘平台接入、真实 provider 质量、真实个人资料路径、自动投递、SaaS、ASR 或会议平台通过。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;align=left;spacing=12;" vertex="1" parent="1"><mxGeometry x="70" y="595" width="1140" height="70" as="geometry" /></mxCell>
        <mxCell id="p6-e1" style="endArrow=block;html=1;rounded=0;strokeColor=#666666;" edge="1" parent="1" source="p6-doc" target="p6-dev"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p6-e2" style="endArrow=block;html=1;rounded=0;strokeColor=#666666;" edge="1" parent="1" source="p6-dev" target="p6-accept"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="7 安全边界证据与复验" id="p81-page-7">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1280" pageHeight="720" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p7-title" value="7 安全边界、证据与复验" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ffffff;fontSize=18;fontStyle=1;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="30" y="18" width="520" height="40" as="geometry" /></mxCell>
        <mxCell id="p7-evidence" value="当前可用证据&lt;br&gt;P8 中文 HTML 报告&lt;br&gt;P8.1 前端审查指导页&lt;br&gt;P5.5 / P6 / P7 自动化候选报告&lt;br&gt;pytest / frontend build / drawio parse&lt;br&gt;多视口真实截图机制" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1"><mxGeometry x="70" y="100" width="330" height="190" as="geometry" /></mxCell>
        <mxCell id="p7-pending" value="仍未验证&lt;br&gt;真实 MiniMax / DeepSeek / OpenAI-compatible provider 质量&lt;br&gt;真实个人资料路径&lt;br&gt;BOSS / 猎聘 / 拉勾账号接入&lt;br&gt;自动抓取、自动沟通、自动投递&lt;br&gt;SaaS / ASR / 会议平台 / MCP / CLI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1"><mxGeometry x="475" y="100" width="330" height="210" as="geometry" /></mxCell>
        <mxCell id="p7-revalidate" value="后续复验要求&lt;br&gt;真实 provider：用户确认 provider、model、次数、预算、数据范围和脱敏报告&lt;br&gt;真实资料：用户指定路径，默认脱敏，不扫描个人目录&lt;br&gt;招聘平台：官方 API 或合规授权后单独立项" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#666666;fontSize=13;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1"><mxGeometry x="880" y="100" width="330" height="210" as="geometry" /></mxCell>
        <mxCell id="p7-scan" value="虚假验收扫描&lt;br&gt;禁止出现：P8.1 已实现、Chatbox-first UI 已验收通过、平台已接入、真实 provider 已通过、真实个人资料已通过、自动投递已通过。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1"><mxGeometry x="70" y="405" width="1140" height="110" as="geometry" /></mxCell>
        <mxCell id="p7-commands" value="文档阶段复验命令&lt;br&gt;drawio XML parse&lt;br&gt;rg 虚假验收关键词&lt;br&gt;git diff --check&lt;br&gt;后续实现阶段再运行 pytest、frontend build 和浏览器截图验收。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1"><mxGeometry x="70" y="575" width="1140" height="90" as="geometry" /></mxCell>
        <mxCell id="p7-e1" value="证据不能替代" style="endArrow=block;html=1;rounded=0;strokeColor=#666666;fontSize=11;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="p7-evidence" target="p7-pending"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p7-e2" value="需单独授权" style="endArrow=block;html=1;rounded=0;strokeColor=#666666;fontSize=11;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="p7-pending" target="p7-revalidate"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
