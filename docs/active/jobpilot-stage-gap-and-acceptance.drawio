        </mxCell>
        <mxCell id="6" value="4 在 Chatbox 继续补项目故事/能力证据&#10;本地故事草稿进入右侧产物台" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5f5e3;strokeColor=#1e8449;fontColor=#10201d;fontStyle=1;spacing=8;arcSize=8;" vertex="1" parent="1">
