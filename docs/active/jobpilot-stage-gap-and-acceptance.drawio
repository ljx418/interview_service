        <mxCell id="p4-e3" value="拆分入口" style="endArrow=block;html=1;rounded=0;strokeColor=#666666;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="p4-strip" target="p4-tools"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p4-e4" value="显式工具动作" style="endArrow=block;html=1;rounded=0;strokeColor=#666666;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="p4-chat" target="p4-tools"><mxGeometry relative="1" as="geometry" /></mxCell>
