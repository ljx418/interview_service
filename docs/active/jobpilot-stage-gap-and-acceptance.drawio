        <mxCell id="5" value="3 左侧市场态势和右侧 search run 更新&#10;展示本地可审计 JD 来源、城市/薪资/技术关键词" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5f5e3;strokeColor=#1e8449;fontColor=#10201d;fontStyle=1;spacing=8;arcSize=8;" vertex="1" parent="1">
