          <mxGeometry x="965" y="100" width="160" height="125" as="geometry" />
        </mxCell>
        <mxCell id="p6_risk" value="红色：禁止 / 打回&lt;br&gt;默认外呼；API Key 泄露；完整真实资料进报告；静态原型冒充实现；P6+ 能力冒充 P5 完成。" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;spacing=8;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="55" y="315" width="360" height="145" as="geometry" />
