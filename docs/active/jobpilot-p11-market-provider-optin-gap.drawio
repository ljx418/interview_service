        <mxCell id="title8" value="P11 安全边界与后续路线" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1f4e79;fontColor=#ffffff;strokeColor=#17365d;fontSize=22;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="30" width="520" height="60" as="geometry"/></mxCell>
        <mxCell id="forbid8" value="高风险禁止默认实现&#xa;招聘平台登录/抓取/绕风控&#xa;长期爬虫/队列/定时任务&#xa;默认 API Key 外呼&#xa;真实 LLM provider&#xa;ASR / MCP / 自动投递 / SaaS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4cccc;strokeColor=#cc0000;fontSize=16;" vertex="1" parent="1"><mxGeometry x="90" y="150" width="480" height="260" as="geometry"/></mxCell>
        <mxCell id="allow8" value="P11 Level1 已实现 / Level2 允许规划&#xa;opt-in provider 状态&#xa;一次性授权调用（Level2 待授权）&#xa;NormalizedJobPost&#xa;JobMarketSnapshot&#xa;source refs / confidence&#xa;中文验收报告" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cfe2f3;strokeColor=#3c78d8;fontSize=16;" vertex="1" parent="1"><mxGeometry x="640" y="150" width="400" height="260" as="geometry"/></mxCell>
        <mxCell id="road8" value="后续路线&#xa;P11 Level1 阶段验收收口&#xa;P11 Level2 指定 provider opt-in（需授权）&#xa;P12 招聘平台合规专项（如需）&#xa;P12 ASR / MCP / 自动投递专项（如需）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#999999;fontSize=16;" vertex="1" parent="1"><mxGeometry x="1110" y="150" width="380" height="260" as="geometry"/></mxCell>
        <mxCell id="options8" value="备选路线取舍&#xa;Opt-in job API provider：采用；可授权可记录，但覆盖依赖 provider&#xa;用户粘贴/公司官网公开源：fallback/manual；低风险但自动化弱&#xa;招聘平台自动抓取：P11 禁止；合规/账号/验证码/封禁风险高&#xa;长期爬虫/队列：P11 禁止；运维、成本和误用风险高" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1"><mxGeometry x="230" y="520" width="1140" height="190" as="geometry"/></mxCell>
      </root>
