        <mxCell id="doc6" value="文档阶段已执行&#xa;DOC-M0 口径锁定&#xa;DOC-M1 PRD/架构/契约&#xa;DOC-M2 docs/drawio 同步&#xa;DOC-M3 覆盖度复审" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#999999;fontSize=15;" vertex="1" parent="1"><mxGeometry x="90" y="160" width="420" height="210" as="geometry"/></mxCell>
        <mxCell id="impl6" value="后续实现阶段&#xa;M0 启动审计&#xa;M1 provider 状态 API&#xa;M2 授权门与日志&#xa;M3 search run / snapshot&#xa;M4 UI 联动&#xa;M5 中文验收报告" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cfe2f3;strokeColor=#3c78d8;fontSize=15;" vertex="1" parent="1"><mxGeometry x="560" y="160" width="390" height="250" as="geometry"/></mxCell>
        <mxCell id="accept6" value="验收分级与证据&#xa;Level 0 文档通过（已完成）&#xa;Level 1 本地实现通过（当前收口）&#xa;Level 2 指定真实 provider opt-in 待授权&#xa;Level 3 多 provider/source 对比待后续&#xa;无凭据不得声明 Level 2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9ead3;strokeColor=#6aa84f;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1040" y="160" width="430" height="270" as="geometry"/></mxCell>
        <mxCell id="rollback6" value="阶段打回条件&#xa;M0：混入平台抓取/长期爬虫/ASR/MCP&#xa;M1：configured 被写成 called&#xa;M2：配置 Key 后自动外呼&#xa;M3：聚合指标没有 source refs&#xa;M4：UI/CLI/report 状态不一致&#xa;M5：无 Level 判定或无截图/命令证据" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4cccc;strokeColor=#cc0000;fontSize=13;" vertex="1" parent="1"><mxGeometry x="410" y="490" width="760" height="230" as="geometry"/></mxCell>
