        <mxCell id="ui3" value="UI Control Plane（需修改）&#xa;TopServiceCenter&#xa;ConversationPlane&#xa;MarketIntelligenceMap&#xa;ArtifactWorkbench" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" vertex="1" parent="1"><mxGeometry x="70" y="140" width="280" height="180" as="geometry"/></mxCell>
        <mxCell id="boundary3" value="Market Provider Boundary（Level1 已实现 / Level2 待授权）&#xa;JobMarketProviderRegistry 已实现&#xa;MarketProviderPolicyGate 已实现&#xa;MarketProviderClient Level2 待授权&#xa;MarketProviderInvocationLog 已实现" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cfe2f3;strokeColor=#3c78d8;fontSize=15;" vertex="1" parent="1"><mxGeometry x="420" y="140" width="310" height="180" as="geometry"/></mxCell>
