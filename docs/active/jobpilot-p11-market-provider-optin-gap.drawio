        <mxCell id="title7" value="P11 里程碑、验收门槛与出门条件" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1f4e79;fontColor=#ffffff;strokeColor=#17365d;fontSize=22;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="30" width="620" height="60" as="geometry"/></mxCell>
        <mxCell id="gate7" value="门槛 A 用户目标清楚&#xa;门槛 B 实体和架构可执行&#xa;门槛 C drawio 可审计&#xa;门槛 D 后续验收可执行&#xa;门槛 E 高风险不混入" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9ead3;strokeColor=#6aa84f;fontSize=16;" vertex="1" parent="1"><mxGeometry x="100" y="160" width="430" height="220" as="geometry"/></mxCell>
        <mxCell id="exit7" value="出门条件&#xa;active docs 口径一致&#xa;drawio 页数 ≤ 8&#xa;文本镜像可审计&#xa;API / 存储 / 验收分级已落盘&#xa;stage review 存在&#xa;Level1 可声明本地通过&#xa;不声明真实 provider Level2 已接入" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#999999;fontSize=16;" vertex="1" parent="1"><mxGeometry x="620" y="160" width="430" height="280" as="geometry"/></mxCell>
        <mxCell id="next7" value="下一步&#xa;完成阶段性验收报告和 Git 收口&#xa;Level2 需用户授权后单独启动&#xa;不得并入招聘平台/ASR/MCP/自动投递" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16;" vertex="1" parent="1"><mxGeometry x="1140" y="160" width="340" height="210" as="geometry"/></mxCell>
        <mxCell id="audit7" value="人类审核问题清单&#xa;1 能否看出 Level1 已实现/需修改/Level2 待授权/禁止项？&#xa;2 每个 PRD 承诺是否落到代码实体或 API？&#xa;3 无真实 provider 凭据时是否不能 Level 2 出门？&#xa;4 failed / fallback / no-results 如何报告？&#xa;5 是否没有承诺平台接入、ASR、MCP、自动投递或 SaaS？" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce5cd;strokeColor=#e69138;fontSize=13;" vertex="1" parent="1"><mxGeometry x="230" y="520" width="1140" height="190" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p11-page-8" name="8 安全边界与后续路线">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
