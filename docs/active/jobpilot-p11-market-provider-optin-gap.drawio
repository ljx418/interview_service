        <mxCell id="existing3" value="Existing Boundary（已实现复用）&#xa;FastAPI Agent Service&#xa;SQLite Workspace&#xa;Artifact / Reports&#xa;P10 CLI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9ead3;strokeColor=#6aa84f;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1180" y="140" width="300" height="180" as="geometry"/></mxCell>
        <mxCell id="evidence3" value="Evidence Layer（Level1 已实现）&#xa;P11MarketAcceptanceReport&#xa;provider invocation evidence&#xa;screenshots / command evidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#999999;fontSize=15;" vertex="1" parent="1"><mxGeometry x="520" y="470" width="520" height="140" as="geometry"/></mxCell>
        <mxCell id="chain3" value="强关联实体链&#xa;UI Control Plane → /api/market/* routes → MarketProviderPolicyGate → MarketProviderClient → MarketDataNormalizer → SourceRefBinder / ConfidenceScorer → JobMarketSnapshot → UI / CLI / HTML report&#xa;禁止只有抽象“Provider 层”而缺少上下游实体" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e2f0d9;strokeColor=#6aa84f;fontSize=13;" vertex="1" parent="1"><mxGeometry x="150" y="650" width="1280" height="110" as="geometry"/></mxCell>
