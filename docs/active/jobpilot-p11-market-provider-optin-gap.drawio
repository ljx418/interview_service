        <mxCell id="title2" value="当前架构与 P11 目标差异" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1f4e79;fontColor=#ffffff;strokeColor=#17365d;fontSize=22;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="30" width="560" height="60" as="geometry"/></mxCell>
        <mxCell id="current2" value="当前 P9.1 / P10 基线&#xa;TopServiceCenter 已显示 Market Provider not_configured&#xa;MarketIntelligenceMap 已有行政区划下钻&#xa;ConversationPlane 已有 Socratic / market prompt&#xa;ArtifactWorkbench 已有事实与故事草稿&#xa;jobpilot CLI 已完成本地命令入口" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9ead3;strokeColor=#6aa84f;fontSize=15;" vertex="1" parent="1"><mxGeometry x="80" y="150" width="500" height="330" as="geometry"/></mxCell>
        <mxCell id="gap2" value="P11 Level1 已补齐&#xa;market provider boundary&#xa;调用前授权拒绝门&#xa;一次性 JobSearchRun&#xa;provider invocation log&#xa;NormalizedJobPost&#xa;JobMarketSnapshot&#xa;source refs / confidence / fallback evidence&#xa;Level2 真实 provider client 待授权" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cfe2f3;strokeColor=#3c78d8;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1010" y="150" width="460" height="330" as="geometry"/></mxCell>
        <mxCell id="bridge2" value="复用 Existing Boundary&#xa;FastAPI Agent Service&#xa;SQLite Workspace&#xa;Artifact / Reports&#xa;P10 CLI evidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" vertex="1" parent="1"><mxGeometry x="660" y="210" width="270" height="210" as="geometry"/></mxCell>
        <mxCell id="risk2" value="三类审计风险&#xa;架构风险：UI/CLI 绕过 API 直调 provider → 必须通过 FastAPI + PolicyGate&#xa;PRD 偏移：滑向招聘平台抓取/全网搜索 → P11 只做 opt-in provider&#xa;验收风险：fixture/fallback 冒充真实市场 → Level 1/2 分级 + source refs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4cccc;strokeColor=#cc0000;fontSize=14;" vertex="1" parent="1"><mxGeometry x="210" y="560" width="1180" height="150" as="geometry"/></mxCell>
        <mxCell id="e1" edge="1" parent="1" source="current2" target="bridge2" style="endArrow=block;html=1;strokeColor=#666666;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" edge="1" parent="1" source="bridge2" target="gap2" style="endArrow=block;html=1;strokeColor=#666666;"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
