<mxfile host="app.diagrams.net" modified="2026-07-13T00:00:00.000Z" agent="JobPilot Codex" version="24.7.17" type="device">
  <diagram id="p11-page-1" name="1 P11目标体验与边界">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title1" value="P11 真实市场数据 Provider Opt-in：目标体验与边界" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1f4e79;fontColor=#ffffff;strokeColor=#17365d;fontSize=22;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="30" width="720" height="60" as="geometry"/></mxCell>
        <mxCell id="goal1" value="目标路径&#xa;Chatbox 发起真实市场查询&#xa;→ 显示 provider 状态 / 费用 / 隐私 / 调用次数&#xa;→ 用户确认一次性 JobSearchRun&#xa;→ NormalizedJobPost / JobMarketSnapshot&#xa;→ 地图、Chatbox、产物台、报告同步 source refs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9ead3;strokeColor=#6aa84f;fontSize=16;" vertex="1" parent="1"><mxGeometry x="70" y="140" width="520" height="250" as="geometry"/></mxCell>
        <mxCell id="boundary1" value="当前 Level1 已实现&#xa;进入阶段性验收收口&#xa;未触发真实外呼&#xa;不声明真实 market provider Level2 通过" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16;" vertex="1" parent="1"><mxGeometry x="650" y="140" width="360" height="180" as="geometry"/></mxCell>
        <mxCell id="decision1" value="架构决策&#xa;采用 opt-in API provider&#xa;+ normalization anti-corruption layer&#xa;+ evidence first&#xa;不采用平台 connector / 长期爬虫 / UI 直连 provider&#xa;取舍：覆盖范围变窄，换取合规、安全、可验收、可回滚" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#999999;fontSize=14;" vertex="1" parent="1"><mxGeometry x="650" y="360" width="360" height="210" as="geometry"/></mxCell>
        <mxCell id="forbid1" value="禁止默认实现&#xa;招聘平台登录 / 抓取 / 绕风控&#xa;长期爬虫 / 定时任务&#xa;默认读取 API Key 外呼&#xa;真实 LLM provider / ASR / MCP&#xa;自动沟通 / 自动投递 / SaaS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4cccc;strokeColor=#cc0000;fontSize=16;" vertex="1" parent="1"><mxGeometry x="1080" y="140" width="420" height="250" as="geometry"/></mxCell>
        <mxCell id="legend1" value="状态色：绿色=Level1 已实现；黄色=需复核/需修改；蓝色=Level2 待授权/待新增；红色=高风险禁止；灰色=审计/证据" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#999999;fontSize=14;" vertex="1" parent="1"><mxGeometry x="70" y="760" width="1430" height="60" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="p11-page-2" name="2 当前架构与P11差距">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
