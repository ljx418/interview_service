        <mxCell id="title4" value="P11 命令流与数据流" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1f4e79;fontColor=#ffffff;strokeColor=#17365d;fontSize=22;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="30" width="460" height="60" as="geometry"/></mxCell>
        <mxCell id="s1" value="1. Provider Status&#xa;GET /api/market/providers/status&#xa;读取 registry / 脱敏配置&#xa;统计 called/failed/fallback&#xa;渲染顶部状态 / CLI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" vertex="1" parent="1"><mxGeometry x="80" y="150" width="320" height="190" as="geometry"/></mxCell>
        <mxCell id="s2" value="2. Provider Check&#xa;POST /api/market/providers/check&#xa;构建 consent preview&#xa;用户确认一次性 check&#xa;调用 provider + 写 invocation log" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cfe2f3;strokeColor=#3c78d8;fontSize=15;" vertex="1" parent="1"><mxGeometry x="620" y="150" width="340" height="190" as="geometry"/></mxCell>
        <mxCell id="s3" value="3. Market Search Run&#xa;POST /api/market/search-runs&#xa;GET /api/market/snapshots/{run_id}&#xa;GET /api/market/source-refs/{id}&#xa;normalize + snapshot + source refs&#xa;地图/Chatbox/产物台联动" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cfe2f3;strokeColor=#3c78d8;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1160" y="150" width="340" height="250" as="geometry"/></mxCell>
        <mxCell id="block4" value="安全门&#xa;UI/CLI 不直调 provider&#xa;不直接写 SQLite&#xa;未确认不外呼&#xa;不抓平台 / 不长期爬虫&#xa;失败或 fallback 不伪造真实市场" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4cccc;strokeColor=#cc0000;fontSize=15;" vertex="1" parent="1"><mxGeometry x="470" y="520" width="640" height="150" as="geometry"/></mxCell>
        <mxCell id="errors4" value="失败分支必须可验收&#xa;PROVIDER_NOT_CONFIGURED：不外呼&#xa;CONSENT_REQUIRED：不创建 running run&#xa;PROVIDER_CALL_FAILED：保留脱敏错误&#xa;NO_RESULTS：不伪造岗位&#xa;FALLBACK_ONLY：只能 Level 1&#xa;POLICY_REJECTED：平台抓取/敏感外发被拒绝" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1160" y="450" width="340" height="250" as="geometry"/></mxCell>
        <mxCell id="a41" edge="1" parent="1" source="s1" target="s2" style="endArrow=block;html=1;strokeColor=#666666;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a42" edge="1" parent="1" source="s2" target="s3" style="endArrow=block;html=1;strokeColor=#666666;"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
