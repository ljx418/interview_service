        <mxCell id="p7-doc" value="文档阶段 蓝&#10;P9.1-DOC-M0 PRD/原型锁定&#10;P9.1-DOC-M1 active docs / roadmap / drawio 同步&#10;P9.1-DOC-M2 覆盖度复审和 false-green 扫描&#10;P9.1-DOC-M3 人工或外部审计认可" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d6eaf8;strokeColor=#2874a6;fontColor=#10201d;spacing=8;arcSize=8;" vertex="1" parent="1"><mxGeometry x="80" y="170" width="480" height="190" as="geometry" /></mxCell>
