        <mxCell id="p6-risk" value="红色禁止&#10;编造学历/年限/公司/贡献/指标&#10;把团队贡献写成本人贡献&#10;无证据指标进入正式简历&#10;普通聊天静默覆盖产物版本" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fadbd8;strokeColor=#c0392b;fontColor=#10201d;spacing=8;arcSize=8;" vertex="1" parent="1"><mxGeometry x="80" y="620" width="1260" height="100" as="geometry" /></mxCell>
